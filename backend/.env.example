# Express Port
PORT=5000

# Security (JWT Keys)
# Generate secure keys using: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="YOUR_JWT_SECRET_KEY"
JWT_REFRESH_SECRET="YOUR_JWT_REFRESH_SECRET_KEY"

# Paystack API Keys (Use test keys initially)
PAYSTACK_SECRET_KEY="sk_test_..."

# Nodemailer SMTP Configuration
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="Hermionehairorg@gmail.com"
# For Gmail, use an App Password: https://support.google.com/accounts/answer/185833
SMTP_PASS="Hermionehairorg78"
SMTP_FROM="Hermionehairorg@gmail.com"

# TOTP / 2FA Secrets Encryption Key
# Generate a secure 32-character key for encrypting TOTP secrets
TOTP_ENCRYPTION_KEY="your_secure_32_character_totp_key"

# Allowed CORS / Frontend Origin ( Vercel, Netlify, or Localhost )
